# =============================================================================
# DevPilot — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — only commit .env.example
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE — Neon Tech (PostgreSQL)
# Get this from: https://console.neon.tech → your project → Connection Details
# Use the "Pooled connection" string for production (goes through PgBouncer)
# -----------------------------------------------------------------------------

# Pooled connection — use this for the app (Prisma runtime queries)
DATABASE_URL="postgresql://devpilot_owner:<password>@<host>.neon.tech/devpilot?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct connection — use this ONLY for Prisma migrations (bypasses PgBouncer)
# In prisma/schema.prisma set: directUrl = env("DIRECT_URL")
DIRECT_URL="postgresql://devpilot_owner:<password>@<host>.neon.tech/devpilot?sslmode=require&connect_timeout=15"

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# JWT
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_long_replace_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_also_64_chars_replace_this
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# -----------------------------------------------------------------------------
# GITHUB OAUTH
# Create at: https://github.com/settings/developers → OAuth Apps → New
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# -----------------------------------------------------------------------------
# GITHUB WEBHOOK
# A shared secret used to verify webhook payloads (HMAC SHA-256)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Note: each Repository row also stores its own webhookSecret in the DB
# -----------------------------------------------------------------------------
GITHUB_WEBHOOK_SECRET=your_global_github_webhook_secret

# -----------------------------------------------------------------------------
# ML SERVICE (FastAPI on Render or local Python)
# -----------------------------------------------------------------------------
ML_SERVICE_URL=http://localhost:8000
ML_API_KEY=your_ml_service_api_key

# -----------------------------------------------------------------------------
# ZEGOCLOUD (Video/Voice SDK)
# Get from: https://console.zegocloud.com
# -----------------------------------------------------------------------------
ZEGO_APP_ID=your_zego_app_id
ZEGO_SERVER_SECRET=your_zego_server_secret

# -----------------------------------------------------------------------------
# CORS — comma-separated allowed origins in production
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
